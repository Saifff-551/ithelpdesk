rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ============================================
    // HELPER FUNCTIONS
    // ============================================
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if user is the document owner
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Get user's profile data
    function getUserProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    // Check if user belongs to the same tenant as the resource
    function belongsToResourceTenant() {
      return isAuthenticated() && 
             resource.data.tenant_id == getUserProfile().tenant_id;
    }
    
    // Check if user is support staff
    function isSupportStaff() {
      return isAuthenticated() && 
             getUserProfile().role_id in ['platform_admin', 'company_admin', 'it_manager', 'support_agent'];
    }
    
    // Check if user is admin (company or platform)
    function isAdmin() {
      return isAuthenticated() && 
             getUserProfile().role_id in ['platform_admin', 'company_admin'];
    }
    
    // Check if user is platform admin
    function isPlatformAdmin() {
      return isAuthenticated() && getUserProfile().role_id == 'platform_admin';
    }
    
    // ============================================
    // TENANTS COLLECTION
    // ============================================
    match /tenants/{tenantId} {
      // Anyone can read tenants (for domain resolution before auth)
      allow read: if true;
      
      // Authenticated users can create a tenant (during registration)
      allow create: if isAuthenticated();
      
      // Only admins can update their own tenant
      allow update: if isAuthenticated() && 
                       getUserProfile().tenant_id == tenantId && 
                       isAdmin();
      
      // Only platform admin can delete tenants
      allow delete: if isPlatformAdmin();
    }
    
    // ============================================
    // USERS COLLECTION
    // ============================================
    match /users/{userId} {
      // Users can create their own profile (during registration or invitation acceptance)
      allow create: if isAuthenticated() && request.auth.uid == userId;
      
      // Users can read profiles from their own tenant, or platform admin can read all
      allow read: if isAuthenticated() && 
                     (isOwner(userId) || 
                      resource.data.tenant_id == getUserProfile().tenant_id || 
                      isPlatformAdmin());
      
      // Users can update their own profile, admins can update any user in their tenant
      allow update: if isAuthenticated() &&
                       (isOwner(userId) || 
                        (resource.data.tenant_id == getUserProfile().tenant_id && isAdmin()));
      
      // No deletions (soft delete via is_active flag)
      allow delete: if false;
    }
    
    // ============================================
    // INVITATIONS COLLECTION
    // ============================================
    match /invitations/{invitationId} {
      // Anyone can read invitations by token (for accepting invites)
      allow read: if true;
      
      // Admins can create invitations for their tenant
      allow create: if isAuthenticated() && 
                       request.resource.data.tenant_id == getUserProfile().tenant_id && 
                       isAdmin();
      
      // Only the invited user can accept (mark as accepted), admins can manage
      allow update: if isAuthenticated() && 
                       (resource.data.email == request.auth.token.email || 
                        (resource.data.tenant_id == getUserProfile().tenant_id && isAdmin()));
      
      // Admins can delete invitations from their tenant
      allow delete: if isAuthenticated() && 
                       resource.data.tenant_id == getUserProfile().tenant_id && 
                       isAdmin();
    }
    
    // ============================================
    // TICKETS COLLECTION
    // ============================================
    match /tickets/{ticketId} {
      // Helper to check if user is the ticket creator
      function isTicketCreator() {
        return resource.data.creator_id == request.auth.uid;
      }
      
      // Read: employees can see their own tickets; staff can see all tenant tickets
      allow read: if isAuthenticated() && 
                     resource.data.tenant_id == getUserProfile().tenant_id &&
                     (isTicketCreator() || isSupportStaff());
      
      // Create: any authenticated tenant user can create tickets in their tenant
      allow create: if isAuthenticated() && 
                       request.resource.data.tenant_id == getUserProfile().tenant_id &&
                       request.resource.data.creator_id == request.auth.uid;
      
      // Update: support staff can update any tenant ticket
      allow update: if isAuthenticated() && 
                       resource.data.tenant_id == getUserProfile().tenant_id &&
                       isSupportStaff();
      
      // Delete: only admins can delete tickets
      allow delete: if isAuthenticated() && 
                       resource.data.tenant_id == getUserProfile().tenant_id && 
                       isAdmin();
      
      // Ticket comments subcollection
      match /comments/{commentId} {
        // Read: ticket participants can read comments
        allow read: if isAuthenticated() && 
                       get(/databases/$(database)/documents/tickets/$(ticketId)).data.tenant_id == getUserProfile().tenant_id;
        
        // Create: authenticated users in the same tenant can add comments
        allow create: if isAuthenticated() && 
                         get(/databases/$(database)/documents/tickets/$(ticketId)).data.tenant_id == getUserProfile().tenant_id &&
                         request.resource.data.author_id == request.auth.uid &&
                         (request.resource.data.is_internal == false || isSupportStaff());
        
        // Update: only comment author can update
        allow update: if isAuthenticated() && resource.data.author_id == request.auth.uid;
        
        // Delete: only admins or comment author
        allow delete: if isAuthenticated() && 
                         (resource.data.author_id == request.auth.uid || isAdmin());
      }
    }
    
    // ============================================
    // SLAs COLLECTION
    // ============================================
    match /slas/{slaId} {
      // Read: any authenticated user in the tenant
      allow read: if isAuthenticated() && 
                     resource.data.tenant_id == getUserProfile().tenant_id;
      
      // Create/Update: admins only
      allow create: if isAuthenticated() && 
                       request.resource.data.tenant_id == getUserProfile().tenant_id && 
                       isAdmin();
      allow update: if isAuthenticated() && 
                       resource.data.tenant_id == getUserProfile().tenant_id && 
                       isAdmin();
      
      // Delete: admins only
      allow delete: if isAuthenticated() && 
                       resource.data.tenant_id == getUserProfile().tenant_id && 
                       isAdmin();
    }
    
    // ============================================
    // KNOWLEDGE BASE COLLECTION
    // ============================================
    match /knowledge_base/{articleId} {
      // Read: any authenticated user in the tenant
      allow read: if isAuthenticated() && 
                     resource.data.tenant_id == getUserProfile().tenant_id;
      
      // Create/Update: support staff
      allow create: if isAuthenticated() && 
                       request.resource.data.tenant_id == getUserProfile().tenant_id && 
                       isSupportStaff();
      allow update: if isAuthenticated() && 
                       resource.data.tenant_id == getUserProfile().tenant_id && 
                       isSupportStaff();
      
      // Delete: admins only
      allow delete: if isAuthenticated() && 
                       resource.data.tenant_id == getUserProfile().tenant_id && 
                       isAdmin();
    }
    
    // ============================================
    // MATIE AI ANALYSES (Audit Trail)
    // ============================================
    match /matie_analyses/{analysisId} {
      // Read: admin-only in the tenant (AI insights are sensitive)
      allow read: if isAuthenticated() && 
                     resource.data.tenant_id == getUserProfile().tenant_id &&
                     isAdmin();
      
      // Create: system-generated (support staff can trigger)
      allow create: if isAuthenticated() && 
                       request.resource.data.tenant_id == getUserProfile().tenant_id &&
                       isSupportStaff();
      
      // No updates or deletes — immutable audit trail
      allow update, delete: if false;
    }
    
    // ============================================
    // AI DECISION LOGS 
    // ============================================
    match /ai_decision_logs/{logId} {
      // Read: admins only
      allow read: if isAuthenticated() && 
                     resource.data.tenantId == getUserProfile().tenant_id &&
                     isAdmin();
      
      // Create: AI Workers or Support staff 
      allow create: if isAuthenticated() && 
                       request.resource.data.tenantId == getUserProfile().tenant_id &&
                       isSupportStaff();
      
      allow update, delete: if false;
    }
    
    // ============================================
    // MATIE ESCALATION PREDICTIONS (Audit Trail)
    // ============================================
    match /matie_escalation_predictions/{predictionId} {
      // Read: admin-only in the tenant
      allow read: if isAuthenticated() && 
                     resource.data.tenant_id == getUserProfile().tenant_id &&
                     isAdmin();
      
      // Create: support staff can trigger predictions
      allow create: if isAuthenticated() && 
                       request.resource.data.tenant_id == getUserProfile().tenant_id &&
                       isSupportStaff();
      
      // Immutable — no updates or deletes
      allow update, delete: if false;
    }
    
    // ============================================
    // MATIE ROUTING FEEDBACK
    // ============================================
    match /matie_feedback/{feedbackId} {
      // Read: admins only (for weight recalibration)
      allow read: if isAuthenticated() && 
                     resource.data.tenant_id == getUserProfile().tenant_id &&
                     isAdmin();
      
      // Create: support staff (when resolving/reassigning tickets)
      allow create: if isAuthenticated() && 
                       request.resource.data.tenant_id == getUserProfile().tenant_id &&
                       isSupportStaff();
      
      // No updates or deletes — immutable feedback log
      allow update, delete: if false;
    }
    
    // ============================================
    // TENANT AI CONFIG
    // ============================================
    match /matie_config/{tenantId} {
      // Read: support staff in the tenant
      allow read: if isAuthenticated() && 
                     tenantId == getUserProfile().tenant_id &&
                     isSupportStaff();
      
      // Write: admins only
      allow write: if isAuthenticated() && 
                      tenantId == getUserProfile().tenant_id &&
                      isAdmin();
    }
    
    // ============================================
    // SECURITY AUDIT LOG
    // ============================================
    match /security_audit_log/{logId} {
      // Read: admin-only (security review)
      allow read: if isAuthenticated() && 
                     resource.data.tenant_id == getUserProfile().tenant_id &&
                     isAdmin();
      
      // Create: any authenticated user (system-generated on access checks)
      allow create: if isAuthenticated() && 
                       request.resource.data.tenant_id == getUserProfile().tenant_id;
      
      // Immutable — no updates or deletes
      allow update, delete: if false;
    }

    // ============================================
    // AUDIT LOGS
    // ============================================
    match /audit_logs/{auditId} {
      // Read: admins
      allow read: if isAuthenticated() && 
                     resource.data.tenantId == getUserProfile().tenant_id &&
                     isAdmin();
                     
      // Create: support staff or system
      allow create: if isAuthenticated() && 
                       request.resource.data.tenantId == getUserProfile().tenant_id &&
                       isSupportStaff();
                       
      allow update, delete: if false;
    }
    
    // ============================================
    // AI METRICS (Observability)
    // ============================================
    match /ai_metrics/{tenantId} {
      // Read: admin-only (dashboards)
      allow read: if isAuthenticated() && 
                     tenantId == getUserProfile().tenant_id &&
                     isAdmin();
      
      // Write: support staff can trigger metric computation
      allow write: if isAuthenticated() && 
                      tenantId == getUserProfile().tenant_id &&
                      isSupportStaff();
      
      // History subcollection — immutable snapshots
      match /history/{snapshotId} {
        allow read: if isAuthenticated() && 
                       tenantId == getUserProfile().tenant_id &&
                       isAdmin();
        allow create: if isAuthenticated() && 
                         tenantId == getUserProfile().tenant_id &&
                         isSupportStaff();
        allow update, delete: if false;
      }
    }

    // ============================================
    // SYSTEM METRICS (Observability)
    // ============================================
    match /system_metrics/{metricId} {
      allow read: if isAuthenticated() && 
                     resource.data.tenantId == getUserProfile().tenant_id &&
                     isAdmin();
                     
      // Normally populated by backend functions
      allow write: if isAuthenticated() && 
                      request.resource.data.tenantId == getUserProfile().tenant_id &&
                      isAdmin();
    }
    
    // ============================================
    // DEFAULT DENY
    // ============================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
